# Copy to .env.local and fill in your values. .env.local is gitignored.
# Every value below has a sensible default — only ANTHROPIC_API_KEY is
# strictly required when CHAT_PROVIDER=anthropic.

# ─── Which LLM the agent uses ───────────────────────────────────
# "ollama" or "anthropic". Defaults to "ollama" if unset.
CHAT_PROVIDER=ollama

# Which LLM the eval pipeline uses as a judge.
# "anthropic" (default — stronger, less biased) or "ollama" (free, local, slower).
# Keep this constant across eval runs when comparing agent providers.
JUDGE_PROVIDER=anthropic

# Required when CHAT_PROVIDER=anthropic OR JUDGE_PROVIDER=anthropic.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Local infra (always needed) ─────────────────────────────────
# Postgres + pgvector — provided by docker-compose.yml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/orderflow

# Ollama daemon — runs on the host, default port
OLLAMA_BASE_URL=http://localhost:11434

# ─── Model choices (optional, sensible defaults) ────────────────
# Override these to experiment with different models.

# Chat model when CHAT_PROVIDER=anthropic
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# Chat model when CHAT_PROVIDER=ollama
# Make sure you've pulled the model: ollama pull <name>
OLLAMA_CHAT_MODEL=llama3.1:8b

# LLM-as-judge model when JUDGE_PROVIDER=anthropic
# Stronger than the agent model on purpose — same-model bias is real.
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6

# LLM-as-judge model when JUDGE_PROVIDER=ollama
# Pick a model that follows structured-output instructions well.
# qwen2.5:14b is a good choice; llama3.1:8b is weaker at strict JSON.
OLLAMA_JUDGE_MODEL=qwen2.5:14b

# ─── Observability (optional — enables LangFuse tracing) ────────
# 1. Run: docker compose -f docker-compose.langfuse.yml up -d
# 2. Open http://localhost:3001 (login: dev@example.com / changeme123)
# 3. Settings → API Keys → Create new API keys, paste below
# Without these, lib/tracing.ts no-ops cleanly.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=http://localhost:3001
